---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const studies = (await getCollection('case-studies')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(studies.flatMap((s) => s.data.categories))].sort();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Our Work | MKTNG.</title>
    <meta name="description" content="Case studies in building durable brands across clean energy, infrastructure, nonprofits, and mission-driven organizations." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@800&family=Poppins:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header id="navbar">
      <div class="container nav-inner">
        <a href="/" class="logo" aria-label="MKTNG.">
          <img src="/mktng-logo.png" alt="MKTNG." class="logo-img" />
        </a>
        <nav class="nav-links">
          <a href="/#work">Work</a>
          <a href="/#how-we-work">How We Work</a>
          <a href="/#about">About</a>
          <a href="/blog">Blog</a>
          <a href="/goldendoodle" class="gd-link">GoldenDoodle</a>
          <a href="/contact" class="btn btn-berry">Let's Talk</a>
        </nav>
      </div>
    </header>

    <section class="work-listing">
      <div class="container">
        <div class="section-header">
          <h1>Our Work</h1>
          <p class="section-sub">Case studies in building durable brands.</p>
        </div>

        <div class="work-grid">
          {studies.map((study) => {
            const primaryCat = study.data.categories?.[0];
            return (
              <a href={`/work/${study.slug}`} class="work-card">
                {study.data.featuredImage ? (
                  <div class="work-thumb">
                    <img
                      src={study.data.featuredImage}
                      alt={study.data.featuredImageAlt || study.data.title}
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="img-ph ratio-16-9 accent-berry">
                    <span class="img-ph-label">[ image ]</span>
                  </div>
                )}
                <div class="work-body">
                  <div class="work-meta">
                    {primaryCat && <span class="label" style="color: var(--berry);">{primaryCat}</span>}
                  </div>
                  <h3>{study.data.title}</h3>
                  <span class="work-link">View Case Study &rarr;</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <footer>
      <div class="container">
        <div class="footer-bottom">
          <a href="/" class="logo" aria-label="MKTNG.">
            <img src="/mktng-logo.png" alt="MKTNG." class="logo-img" />
          </a>
          <span class="footer-copy">&copy; 2026 MKTNG. All rights reserved.</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const nav = document.getElementById('navbar');
        if (!nav) return;
        window.addEventListener('scroll', () => {
          nav.classList.toggle('is-scrolled', window.scrollY > 40);
        });
      })();
    </script>
  </body>
</html>

<style>
  .work-listing {
    padding: 9rem 0 4rem;
    background: var(--ice);
  }

  .work-listing .section-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    max-width: 640px;
  }

  .section-sub {
    opacity: 0.65;
    margin-top: 0.5rem;
    font-size: 1.1rem;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .work-card {
    background: var(--white);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .work-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .work-thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .work-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .work-card:hover .work-thumb img {
    transform: scale(1.03);
  }

  .work-body {
    padding: 1.25rem;
  }

  .work-body h3 {
    font-size: 1.1rem;
    margin: 0.5rem 0 0.75rem;
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
