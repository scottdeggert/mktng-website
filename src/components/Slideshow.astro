---
interface Props {
  images: string[];
  alt?: string;
}

const { images, alt = 'Case study image' } = Astro.props;
---

{images.length > 0 && (
  <div class="slideshow" data-slideshow>
    <div class="slideshow-track">
      {images.map((src, i) => (
        <div class="slideshow-slide" data-index={i}>
          <img src={src} alt={`${alt} – ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
    {images.length > 1 && (
      <>
        <button class="slideshow-btn prev" data-prev aria-label="Previous slide">&lsaquo;</button>
        <button class="slideshow-btn next" data-next aria-label="Next slide">&rsaquo;</button>
        <div class="slideshow-dots">
          {images.map((_, i) => (
            <button class={`slideshow-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`} />
          ))}
        </div>
      </>
    )}
  </div>
)}

<style>
  .slideshow {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-light);
    margin: 2rem 0;
  }

  .slideshow-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .slideshow-slide {
    min-width: 100%;
    flex-shrink: 0;
  }

  .slideshow-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  .slideshow-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.9);
    border: none;
    width: 44px;
    height: 44px;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
  }

  .slideshow-btn:hover {
    background: rgba(255, 255, 255, 1);
  }

  .slideshow-btn.prev {
    left: 0.75rem;
  }

  .slideshow-btn.next {
    right: 0.75rem;
  }

  .slideshow-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }

  .slideshow-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid white;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .slideshow-dot.active {
    background: white;
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-slideshow]').forEach(function (el) {
    var track = el.querySelector('.slideshow-track');
    var slides = el.querySelectorAll('.slideshow-slide');
    var dots = el.querySelectorAll('.slideshow-dot');
    var current = 0;
    var total = slides.length;

    function goTo(i) {
      current = ((i % total) + total) % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function (d, idx) {
        d.classList.toggle('active', idx === current);
      });
    }

    var prevBtn = el.querySelector('[data-prev]');
    var nextBtn = el.querySelector('[data-next]');
    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.dot)); });
    });
  });
</script>
