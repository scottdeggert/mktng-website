---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MKTNG. | Build for Resilience</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@800&family=Poppins:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- 1. NAV -->
    <header id="navbar">
      <div class="container nav-inner">
        <a href="/" class="logo" aria-label="MKTNG.">
          <img
            src="/mktng-logo.png"
            alt="MKTNG."
            class="logo-img"
          />
        </a>
        <nav class="nav-links">
          <a href="#work">Work</a>
          <a href="#how-we-work">How We Work</a>
          <a href="#about">About</a>
          <a href="#blog">Blog</a>
          <a href="/goldendoodle" class="gd-link">GoldenDoodle</a>
          <a href="/contact" class="btn btn-berry">Let's Talk</a>
        </nav>
      </div>
    </header>

    <!-- 2. HERO -->
    <section class="hero">
      <div class="container">
        <p class="estb">Est. 2015</p>
        <h1 class="hero-title">Build for Resilience</h1>
        <p class="hero-quote">
          "Conditions change. The work of building something durable doesn't."
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn-berry">Start a Conversation</a>
        </div>
      </div>
    </section>

    <!-- 2. PILLARS -->
    <section id="how-we-work" class="pillars">
      <div class="container">
        <div class="section-header">
          <h2>How we build durable brands.</h2>
        </div>
        <div class="pillars-grid">
          <div class="pillar-card">
            <div class="pillar-num" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z" />
                <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12" />
                <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17" />
              </svg>
            </div>
            <h3>Foundation</h3>
            <p class="pillar-desc">
              The structural work that has to be solid before anything else can scale.
              Brand architecture, core messaging, web infrastructure, crisis preparedness.
            </p>
            <div class="pillar-tags">
              Brand Architecture · Core Messaging · Web Infrastructure · Crisis Preparedness
            </div>
          </div>
          <div class="pillar-card">
            <div class="pillar-num" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                <path d="M16 3.128a4 4 0 0 1 0 7.744" />
                <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                <circle cx="9" cy="7" r="4" />
              </svg>
            </div>
            <h3>Community</h3>
            <p class="pillar-desc">
              Sustained, transparent dialogue that turns audiences into advocates. Public
              relations, media strategy, stakeholder engagement, social and content.
            </p>
            <div class="pillar-tags">
              Public Relations · Media Strategy · Stakeholder Engagement · Social &amp;
              Content
            </div>
          </div>
          <div class="pillar-card">
            <div class="pillar-num" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
              </svg>
            </div>
            <h3>Innovation</h3>
            <p class="pillar-desc">
              Modern tooling applied to real problems — not as a feature, as a standard.
              AI integration, rapid execution, adaptive systems, predictive analytics.
            </p>
            <div class="pillar-tags">
              AI Integration · Rapid Execution · Adaptive Systems · Predictive Analytics
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. SECTORS -->
    <section class="sectors">
      <div class="container">
        <div class="bento-grid">
          <div class="bento-card cyan">
            <div class="img-ph ratio-16-9 accent-cyan">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <span class="label cyan">Sector 01</span>
            <h3>Clean Energy &amp; Infrastructure</h3>
            <p>
              Partnering with utilities, public agencies, and clean tech innovators to
              navigate complex transitions.
            </p>
          </div>
          <div class="bento-card berry">
            <div class="img-ph ratio-16-9 accent-berry">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <span class="label berry">Sector 02</span>
            <h3>Mission-Driven Nonprofits</h3>
            <p>
              Empowering trauma-informed orgs, homeless services, foster care, and
              frontline social services.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. CASE STUDIES -->
    <section id="work" class="case-studies">
      <div class="container">
        <div class="section-header">
          <h2>Case studies in durability.</h2>
        </div>
        <div class="case-grid">
          <div class="case-card">
            <div class="img-ph ratio-16-9 accent-cyan">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="case-card-body">
              <span class="label cyan">Clean Energy &amp; Infrastructure Innovation</span>
              <h3>Building community trust through contested infrastructure</h3>
              <p>
                How we navigated local resistance and regulatory complexity to secure
                public buy-in for a major regional grid modernization project.
              </p>
              <a href="#" class="case-link cyan">Read the story →</a>
            </div>
          </div>
          <div class="case-card">
            <div class="img-ph ratio-16-9 accent-berry">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="case-card-body">
              <span class="label berry">Mission-Driven Organizations</span>
              <h3>Foster care rebranding led by the families themselves</h3>
              <p>
                Replacing institutional language with trauma-informed, lived-experience
                voice to increase resource family recruitment.
              </p>
              <a href="#" class="case-link berry">Read the story →</a>
            </div>
          </div>
          <div class="case-card">
            <div class="img-ph ratio-16-9 accent-gd">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="case-card-body">
              <span class="label gd">Professional Services</span>
              <h3>Building a market-proof brand for a regional professional services firm</h3>
              <p>
                How we built a brand foundation and community presence that drove
                consistent growth through a period of significant market disruption.
              </p>
              <a href="#" class="case-link gd">Read the story →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. LOGO STRIP -->
    <section class="logo-strip">
      <div class="container">
        <span class="label">Organizations we've worked with</span>
        <div class="logos">
          <div class="logo-shape w1"></div>
          <div class="logo-shape w2"></div>
          <div class="logo-shape w3"></div>
          <div class="logo-shape w6"></div>
          <div class="logo-shape w5"></div>
          <div class="logo-shape w4"></div>
          <div class="logo-shape w7"></div>
          <div class="logo-shape w8"></div>
        </div>
      </div>
    </section>

    <!-- 6. VERTICALS -->
    <section id="about" class="verticals">
      <div class="container">
        <div class="section-header wide">
          <h2>Organizations we serve</h2>
          <p class="verticals-intro">
            We build durable brands across a wide range of industries. But we forged this
            methodology in two of the most demanding environments we know: the regulatory
            complexity of clean energy infrastructure, and the high-stakes, human-first
            world of mission-driven nonprofits. If the foundation holds there, it holds
            anywhere.
          </p>
        </div>
        <div class="verticals-grid">
          <div class="vertical-panel">
            <h3>Clean Energy &amp; Infrastructure Innovation</h3>
            <p>
              Utilities, public agencies, and clean tech companies operating where the
              public is watching, regulators are engaged, and the margin for a
              communications mistake is genuinely small. We've been in these rooms long
              enough to know what breaks and what holds.
            </p>
          </div>
          <div class="vertical-panel">
            <h3>Mission-Driven Organizations</h3>
            <p>
              Human-first. Dignity-centered. The organizations doing this work are
              building the infrastructure that holds communities together — and they
              deserve communications built with the same intention.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. TESTIMONIALS -->
    <section class="testimonials">
      <div class="container">
        <div class="section-header">
          <h2>What clients say.</h2>
        </div>
        <div class="test-grid">
          <div class="test-card">
            <blockquote>[Energy sector pull quote]</blockquote>
            <div class="test-author">
              <div class="avatar cyan">JS</div>
              <div class="author-info">
                <strong>James S.</strong>
                <span>Title, Organization</span>
              </div>
            </div>
          </div>
          <div class="test-card">
            <blockquote>[Nonprofit sector pull quote]</blockquote>
            <div class="test-author">
              <div class="avatar berry">MR</div>
              <div class="author-info">
                <strong>Maria R.</strong>
                <span>Title, Organization</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 8. AI METHODOLOGY -->
    <section class="ai-methodology">
      <div class="container">
        <div class="ai-inner">
          <h2 class="ai-heading">We use AI. Openly,<br />and on purpose.</h2>
          <p class="ai-prose">
            Every engagement runs with AI in the room — every meeting, every brief, every
            recommendation. Not as a shortcut, as an accelerant. The thinking is still
            ours. What AI changes is the speed: from information to insight to action,
            faster than any traditional agency timeline.
          </p>
        </div>
      </div>
      <div class="ai-bridge-band">
        <div class="container">
          <p class="ai-bridge">
            When the right tools didn't exist for the clients we cared about most, we
            built them. That's GoldenDoodle AI.
          </p>
          <a href="/ai" class="work-link berry">How we work with AI →</a>
        </div>
      </div>
    </section>

    <!-- 9. GOLDENDOODLE -->
    <section class="goldendoodle">
      <div class="container">
        <span class="gd-badge">AI Startup</span>
        <div class="gd-grid">
          <div class="gd-story">
            <h2>We built what was missing.</h2>
            <p>
              Working alongside frontline nonprofits, we kept seeing a critical gap:
              organizations doing the hardest social services work had the least access to
              modern, trauma-informed communications tools.
            </p>
            <p>
              So, we built one. What started as an internal tool grew into an independent
              startup dedicated to scaling impact through accessible AI.
            </p>
            <a href="/goldendoodle" class="btn btn-outline gd-btn">
              Read the full story →
            </a>
          </div>
          <div class="gd-panel">
            <div class="gd-panel-name">
              <img
                src="/GD%20Logo%20Trans%20for%20light.png"
                alt="GoldenDoodle AI"
              />
            </div>
            <p class="gd-positioning">
              The first trauma-informed AI content platform for mission-driven
              organizations.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 10. INSIGHTS -->
    <section id="blog" class="insights">
      <div class="container">
        <div class="section-header">
          <h2>Insights &amp; Methodology</h2>
        </div>
        <div class="insights-grid">
          <div class="insight-card">
            <div class="img-ph ratio-3-2 accent-cyan">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="insight-body">
              <div class="insight-meta">
                <span class="label" style="color: var(--cyan);">
                  Clean Energy &amp; Infrastructure
                </span>
                <span>Oct 12</span>
              </div>
              <h3>Modernizing Rate Case Communications</h3>
              <p>
                How to discuss infrastructure investment with ratepayers when economic
                anxieties are high.
              </p>
              <a href="/blog" class="work-link">Read →</a>
            </div>
          </div>
          <div class="insight-card">
            <div class="img-ph ratio-3-2 accent-berry">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="insight-body">
              <div class="insight-meta">
                <span class="label" style="color: var(--berry);">
                  Mission-Driven Organizations
                </span>
                <span>Sep 28</span>
              </div>
              <h3>The ROI of Trauma-Informed Language</h3>
              <p>
                Why shifting your organization's vocabulary changes more than just your
                marketing materials.
              </p>
              <a href="/blog" class="work-link">Read →</a>
            </div>
          </div>
          <div class="insight-card">
            <div class="img-ph ratio-3-2 accent-gd">
              <span class="img-ph-label">[ image ]</span>
            </div>
            <div class="insight-body">
              <div class="insight-meta">
                <span class="label" style="color: var(--gd);">Innovation</span>
                <span>Sep 05</span>
              </div>
              <h3>Building AI for AI-Skeptical Organizations</h3>
              <p>
                The roadmap to implementing artificial intelligence in sectors where human
                connection is everything.
              </p>
              <a href="/blog" class="work-link">Read →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 11. FOOTER CTA -->
    <section id="contact" class="footer-cta">
      <div class="container">
        <h2>
          Ready to build for <span style="color: var(--berry);">resilience</span>?
        </h2>
        <p>We work deeply with a small number of clients at a time.</p>
        <a href="/contact" class="btn btn-berry">Let's Talk</a>
      </div>
    </section>

    <!-- 12. FOOTER -->
    <footer>
      <div class="container">
        <div class="footer-bottom">
          <a href="/" class="logo" aria-label="MKTNG.">
            <img
              src="/GD%20Logo%20Trans%20for%20light.png"
              alt="MKTNG."
              class="logo-img"
            />
          </a>
          <span class="footer-copy">© 2026 MKTNG. All rights reserved.</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const nav = document.getElementById('navbar');
        if (!nav) return;
        window.addEventListener('scroll', () => {
          nav.classList.toggle('is-scrolled', window.scrollY > 40);
        });
      })();
    </script>
  </body>
</html>

